{
  "name": "tox-starter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@tailwindcss/postcss": "^4.3.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "next-auth": "^4.24.14",
    "tailwindcss": "^4.3.1"
  }
}
